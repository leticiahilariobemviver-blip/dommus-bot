# ─── CRM Dommus ───────────────────────────────────────────────────────────────

# URL da página de LOGIN do Dommus
DOMMUS_URL=https://painel.dommus.com.br/login

# URL do Kanban/Leads (pode ser diferente da URL de login)
DOMMUS_LEADS_URL=https://leads.dommus.com.br/

# Credenciais de acesso
DOMMUS_USER=seu@email.com
DOMMUS_PASSWORD=suasenha

# ─── Servidor ─────────────────────────────────────────────────────────────────

# Porta HTTP do robô (padrão: 3000)
PORT=3000

# Token de autenticação — qualquer string secreta longa (ex: uuid v4)
# O n8n e qualquer cliente devem enviar: x-token: <valor>
ROBO_TOKEN=troque-por-um-segredo-longo-e-aleatorio
